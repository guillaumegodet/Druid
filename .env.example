# ── Grist ──────────────────────────────────────────────────────────────────────
# Demo (public, read-only): bWVMq9SHJes7ngCuHsN9iD
VITE_GRIST_DOC_ID=bWVMq9SHJes7ngCuHsN9iD

# Grist API key — required to write back to Grist (create/update records).
# Leave empty for read-only demo mode.
VITE_GRIST_API_KEY=

# Grist table names (must match your document)
VITE_GRIST_RESEARCHERS_TABLE=Annuaire
VITE_GRIST_STRUCTURES_TABLE=Structures

# ── Application ────────────────────────────────────────────────────────────────
DRUID_PORT=3000

# Public URL of the application (used for Keycloak redirect URI)
APP_URL=http://localhost:3000

# ── Authentication ─────────────────────────────────────────────────────────────
# Set to true to enable Keycloak authentication (recommended for production).
# When false, the application is accessible without login.
DRUID_AUTH_ENABLED=false

# Required only when DRUID_AUTH_ENABLED=true
KEYCLOAK_URL=http://your-keycloak:8080
KEYCLOAK_REALM=your-realm
KEYCLOAK_CLIENT_ID=druid
SESSION_SECRET=change-me-with-a-random-string

# ── LDAP Sync (optional) ───────────────────────────────────────────────────────
# Enables the "Sync LDAP" button to enrich researcher records with LDAP data.
# Leave empty to disable LDAP sync.
LDAP_URL=ldaps://your-ldap-server
LDAP_BIND_DN=cn=service,ou=Applications,dc=example,dc=fr
LDAP_BIND_PW=your-password
LDAP_BASE_DN=ou=People,dc=example,dc=fr
LDAP_FILTER=(&(objectClass=supannPerson)(population=PERSONNEL))
